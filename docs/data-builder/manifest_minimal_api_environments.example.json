{
  "manifest_version": "1.0",
  "database_context": {
    "dialect": "mysql8",
    "connection_ref": "ui_mysql",
    "database": "ai_automation_db",
    "tables": [{ "name": "api_environments", "role": "primary" }]
  },
  "generation": {
    "mode": "template",
    "instruction_echo": "最小示例：api_environments，两批共 4 行",
    "sql_template": "INSERT INTO `api_environments` (`name`, `base_url`) VALUES (:name, :base_url)",
    "bindings": [
      {
        "placeholder": "name",
        "column": "name",
        "strategy": "fingerprint_remark",
        "params": { "merge_mode": "append" }
      },
      {
        "placeholder": "base_url",
        "column": "base_url",
        "strategy": "literal",
        "params": { "value": "https://l3.example/min" }
      }
    ],
    "batching": {
      "total_rows": 4,
      "batch_size": 2,
      "batch_count": 2,
      "batches": [
        { "batch_index": 0, "row_count": 2, "label": "b0" },
        { "batch_index": 1, "row_count": 2, "label": "b1" }
      ]
    },
    "post_insert_sql": [],
    "state_machine": null
  },
  "fingerprint": {
    "strategy": "row_map_only",
    "remark_column": null,
    "marker": {
      "format": "prefixed_token",
      "prefix": "DB_TASK_",
      "value_template": "${prefix}${task_id}"
    },
    "row_map": {
      "enabled": true,
      "async_flush": false,
      "table": "data_builder_row_map"
    }
  },
  "assertions": [
    {
      "id": "asrt_row_count_for_task_marker",
      "name": "本任务写入行数",
      "assertion_type": "scalar",
      "severity": "error",
      "sql": "SELECT COUNT(*) AS c FROM `api_environments` WHERE `name` LIKE CONCAT('%', :task_marker, '%')",
      "expect": { "kind": "row_count_eq", "value": 4, "column": "c" },
      "rationale": "name 使用 fingerprint_remark(append)，含 task 标记；与 total_rows 一致",
      "run_after_batch": null
    }
  ],
  "cleanup": {
    "mode": "row_map",
    "requires_confirm": true,
    "plans": [{ "table": "api_environments", "order": 10, "source": "row_map" }]
  },
  "meta": {
    "source": "ui",
    "compliance": { "production_row_sampling": false },
    "data_builder": { "insert_pk_column": "id" }
  }
}
