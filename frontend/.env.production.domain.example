# 经 Nginx 以 https://hahaliu.cn 对外，且 API 为 /api、执行引擎为 /engine 时使用。
# 复制为 .env.production 后再执行 npm run build 或构建前端 Docker 镜像：
#   copy .env.production.domain.example .env.production   (Windows)
#   cp .env.production.domain.example .env.production     (Linux/macOS)

VITE_MGMT_API_URL=/api
VITE_EXEC_ENGINE_URL=/engine
