# 统一使用 LF 行尾（Unix 风格），避免 Windows CRLF 导致的乱码和 Git 警告
* text=auto eol=lf

# 明确声明文本文件类型为 UTF-8
*.vue    text eol=lf
*.ts     text eol=lf
*.js     text eol=lf
*.json   text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.py     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf
*.conf   text eol=lf
*.env    text eol=lf
*.sh     text eol=lf

# 二进制文件不做行尾转换
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
